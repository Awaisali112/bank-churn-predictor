# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[oc]
*.pyo
build/
dist/
wheels/
*.egg-info/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── uv ────────────────────────────────────────────────────────────────────────
# uv.lock is intentionally committed (reproducible installs)
# but the cache is not
.uv/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Model artifacts ───────────────────────────────────────────────────────────
# Trained models and scalers are generated by `python main.py`
# and should not be committed to version control.
models/*.pkl
models/*.joblib

# ── Output plots ──────────────────────────────────────────────────────────────
# Generated by the pipeline — reproducible, not source files.
outputs/*.png
outputs/*.jpg
outputs/*.csv

# ── Data ──────────────────────────────────────────────────────────────────────
# Raw data files — often large or sensitive.
# Remove this line if you want to commit the sample dataset.
# data/*.csv

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
*.env
secrets.json

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# ── pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── mypy / ruff / linting ─────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
